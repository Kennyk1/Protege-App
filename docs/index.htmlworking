    <a href="https://github.com/Kennyk1/Protege-App/raw/main/base.apk" class="btn-primary">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Download APK
    </a>
    <a href="https://github.com/Kennyk1/Protege-App" class="btn-secondary" target="_blank">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
      View on GitHub
    </a>
  </div>

  <!-- Phone mockup -->
  <div class="mockup-wrap">
    <div class="mockup-glow"></div>
    <div class="mockup">
      <img src="screenshot.jpg" alt="Protege App Screenshot" onerror="this.style.display='none';this.parentElement.style.background='#10101e';this.parentElement.style.height='500px';this.parentElement.innerHTML+='<div style=\'display:flex;align-items:center;justify-content:center;height:500px;color:#6b6b8a;font-size:14px;\'>Screenshot</div>'"/>
    </div>
  </div>
</div>

<!-- STATS -->
<div style="padding:0 24px;position:relative;z-index:1;max-width:600px;margin:0 auto;">
  <div class="stats">
    <div class="stat">
      <div class="stat-val">4.3MB</div>
      <div class="stat-label">App Size</div>
    </div>
    <div class="stat">
      <div class="stat-val">Free</div>
      <div class="stat-label">No charges</div>
    </div>
    <div class="stat">
      <div class="stat-val">v1.0</div>
      <div class="stat-label">Version</div>
    </div>
  </div>
</div>

<!-- FEATURES -->
<section>
  <div class="section-label">What's inside</div>
  <h2 class="section-title">More than just a calculator</h2>
  <p class="section-sub">Protege looks like a simple calculator on the outside — but inside it's a full featured smart app.</p>

  <div class="features">
    <div class="feature">
      <div class="feature-icon fi-purple">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#6c63ff" stroke-width="1.8" stroke-linecap="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
      </div>
      <div>
        <div class="feature-title">Voice Calculator</div>
        <div class="feature-desc">Speak your calculations and get instant answers. Supports complex math, algebra, percentages and unit conversions.</div>
