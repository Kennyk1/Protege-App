        <div class="feature-desc">Earn rewards by inviting friends. Track your referrals and bonuses in real time.</div>
      </div>
    </div>
    <div class="feature">
      <div class="feature-icon fi-blue">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#52aaff" stroke-width="1.8" stroke-linecap="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
      </div>
      <div>
        <div class="feature-title">Movies & Entertainment</div>
        <div class="feature-desc">Watch YouTube and TikTok videos directly inside the app without leaving.</div>
      </div>
    </div>
  </div>
</section>

<!-- DOWNLOAD -->
<section id="download">
  <div class="download-box">
    <div style="width:64px;height:64px;background:linear-gradient(135deg,rgba(108,99,255,0.2),rgba(0,212,170,0.2));border-radius:20px;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
      <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="url(#dg)" stroke-width="2" stroke-linecap="round">
        <defs><linearGradient id="dg" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#6c63ff"/><stop offset="100%" stop-color="#00d4aa"/></linearGradient></defs>
        <rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="8" x2="12" y2="14"/><polyline points="9 11 12 14 15 11"/>
      </svg>
    </div>
