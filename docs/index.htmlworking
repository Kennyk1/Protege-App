<div class="hero">
  <div class="hero-badge">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a09eff" stroke-width="2" stroke-linecap="round"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M9 11V7a3 3 0 0 1 6 0v4"/><circle cx="9" cy="16" r="1" fill="#a09eff" stroke="none"/><circle cx="15" cy="16" r="1" fill="#a09eff" stroke="none"/></svg>
    AI Powered · Free to Download
  </div>
  <h1 class="hero-title">The Calculator<br/>That <span>Does Everything</span></h1>
